# Strava API credentials — get these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REFRESH_TOKEN=your_refresh_token

# Optional: activities per page in the interactive list (default: 10, max 200)
# PAGE_SIZE=10

# ─── Rider Profile (optional — unlocks advanced metrics) ───
# Set these to enable: IF, TSS, W/kg, power zones, relative effort
# RIDER_WEIGHT_KG=75
# RIDER_FTP_W=250
# RIDER_MAX_HR=195          # Cycling max HR
# RIDER_LTHR=165            # Cycling lactate threshold HR (unlocks LTHR-based zones)
# RIDER_REST_HR=50

# ─── Running-specific overrides (optional) ───
# RUNNER_RFTP_W=300          # Running FTP (pace in W). If not set, cycling FTP is used with a warning.
# RUNNER_MAX_HR=200          # Running max HR (usually 5-10 bpm higher than cycling). Falls back to RIDER_MAX_HR.
# RUNNER_LTHR=173            # Running lactate threshold HR. Falls back to RIDER_LTHR then RUNNER_MAX_HR.

# ─── AI Analysis (add any/all — auto-fallback: Gemini → Groq → OpenRouter → OpenAI) ───

# Option 1: Google Gemini (free tier) — https://aistudio.google.com/apikey
# GEMINI_API_KEY=AI...
# GEMINI_MODEL=gemini-2.5-flash

# Option 2: Groq (free, very fast) — https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Option 3: OpenRouter (pay-per-use, many models) — https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324

# Option 4: OpenAI (GPT-4o) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o


