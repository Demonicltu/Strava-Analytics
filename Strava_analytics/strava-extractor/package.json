{
  "name": "strava-extractor",
  "version": "1.0.0",
  "description": "Extract detailed Strava activity data for AI analysis",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "crunch": "tsx src/pre_analyze.ts",
    "analyze": "tsx src/analyze.ts",
    "update": "tsx src/update_strava.ts",
    "fast": "tsx src/fast.ts",
    "build": "tsc",
    "build:bundle": "tsx build.ts",
    "dev": "tsx --watch src/index.ts"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
